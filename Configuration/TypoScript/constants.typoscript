# Features constant Includes:
@import 'EXT:ns_feedback/Configuration/TypoScript/FeaturesConstants/appearanceSettings_constants.typoscript'
@import 'EXT:ns_feedback/Configuration/TypoScript/FeaturesConstants/commonSettings_constants.typoscript'

plugin.tx_nsfeedback_feedback {
    view {
        # cat=plugin.tx_nsfeedback_feedback/file; type=string; label=Path to template root (FE)
        templateRootPath = EXT:ns_feedback/Resources/Private/Templates/
        # cat=plugin.tx_nsfeedback_feedback/file; type=string; label=Path to template partials (FE)
        partialRootPath = EXT:ns_feedback/Resources/Private/Partials/
        # cat=plugin.tx_nsfeedback_feedback/file; type=string; label=Path to template layouts (FE)
        layoutRootPath = EXT:ns_feedback/Resources/Private/Layouts/
    }
}